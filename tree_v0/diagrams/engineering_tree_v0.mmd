flowchart TD

    root["Engineering Tree v0"]

    trunk["Trunk Foundations"]

    software["Software Systems"]
    embedded["Embedded & Hardware"]
    energy["Energy & Automation"]
    data["Data & AI"]

    projS["Projects & Proof"]
    projE["Projects & Proof"]
    projG["Projects & Proof"]
    projD["Projects & Proof"]

    monetization["Monetization Ladder"]
    opportunity["Economic Opportunity"]

    root --> trunk

    trunk --> software
    trunk --> embedded
    trunk --> energy
    trunk --> data

    software --> projS
    embedded --> projE
    energy --> projG
    data --> projD

    projS --> monetization
    projE --> monetization
    projG --> monetization
    projD --> monetization

    monetization --> opportunity

